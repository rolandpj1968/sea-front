(translation-unit
  (template (params (param ? "T"))
    (class-def "uptr"
      (var-decl (func-type void ((ptr dependent T))) "uptr" )))
  (class-def "C"
    (func-def void "f" (params)
      (block
        (var-decl struct uptr<struct MR> "p" (ctor-args (cast struct MR (null))))))
    (class-def "MR")))
