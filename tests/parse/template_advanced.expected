(translation-unit
  (template (params (param ? "T"))
    (class-def "Box"
      (var-decl int "val")))
  (template (params (param ? "A") (param ? "B"))
    (class-def "Pair"
      (var-decl int "a")
      (var-decl int "b")))
  (template (params (param ? "T"))
    (func-def int "identity" (params (param int "x"))
      (block
        (return (ident "x")))))
  (template (params (param int "N"))
    (class-def "Fixed"
      (var-decl (array int 10) "data")))
  (template (params)
    (class-def "Box"
      (var-decl int "special")))
  (func-def int "main" (params)
    (block
      (var-decl struct Box "deep")
      (var-decl struct Pair "mixed")
      (var-decl int "x" (call (ident "identity") (num 42)))
      (var-decl struct Fixed "f")
      (return (ident "x")))))
