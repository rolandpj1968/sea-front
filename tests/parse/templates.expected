(translation-unit
  (template (params (param ? "T"))
    (func-def dependent T "add" (params (param dependent T "a") (param dependent T "b"))
      (block
        (return (+ (ident "a") (ident "b"))))))
  (template (params (param ? "T") (param int "N"))
    (class-def "Array"
      (var-decl (array dependent T 10) "data")))
  (template (params (param ? "T"))
    (class-def "Box"
      (var-decl dependent T "val")))
  (template (params (param ? "A") (param ? "B"))
    (class-def "Pair"
      (var-decl dependent A "first")
      (var-decl dependent B "second")))
  (func-def int "main" (params)
    (block
      (var-decl int "x" (call (template-id "add" (var-decl int)) (num 1) (num 2)))
      (var-decl struct Array "arr")
      (var-decl struct Box "nested")
      (var-decl struct Box "complex")
      (return (ident "x")))))
