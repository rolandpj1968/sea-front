#!/bin/sh
# sea-front-cc — wrapper that acts as a C++ compiler for build systems.
#
# Pipeline: preprocess (g++) → transpile (sea-front) → compile C (gcc)
#
# Usage: sea-front-cc [compiler-flags] -c -o output.o input.cpp
#        sea-front-cc [compiler-flags] -o output input.o ...   (link mode)
#
# Environment:
#   SEA_FRONT    — path to sea-front binary (default: build/sea-front)
#   SEA_CC       — C compiler for compiling emitted C (default: cc)
#   SEA_CPP      — C++ preprocessor (default: g++)
#   SEA_VERBOSE  — set to 1 for debug output

set -e

SEA_FRONT="${SEA_FRONT:-$(dirname "$0")/../build/sea-front}"
SEA_CC="${SEA_CC:-cc}"
SEA_CPP="${SEA_CPP:-g++}"
SEA_VERBOSE="${SEA_VERBOSE:-0}"

log() {
    [ "$SEA_VERBOSE" = "1" ] && echo "[sea-front-cc] $*" >&2 || true
}

# Parse arguments to understand what mode we're in.
# We need to identify:
#   - input files (.cpp, .cc, .cxx, .C, .c)
#   - output file (-o foo)
#   - compile-only (-c)
#   - preprocessor flags (-I, -D, -U, -include, -isystem, -std=)
#   - other flags passed through to the C compiler
MODE="link"
OUTPUT=""
INPUTS=""
CPP_FLAGS=""
CC_FLAGS=""
STD_FLAG=""
SKIP_NEXT=0

for arg in "$@"; do
    if [ "$SKIP_NEXT" = "1" ]; then
        SKIP_NEXT=0
        continue
    fi
    case "$arg" in
        -c)
            MODE="compile"
            ;;
        -o)
            # Next arg is output file — handled in paired loop below
            ;;
        -E|-S|-M|-MM)
            # Preprocessing/assembly/dependency modes — pass through to preprocessor
            exec $SEA_CPP "$@"
            ;;
        -shared|-static)
            CC_FLAGS="$CC_FLAGS $arg"
            ;;
        *)
            ;;
    esac
done

# Shell-quote a single argument so it survives `eval`.
# Wraps in single quotes and escapes any embedded single quotes.
# Required because args like  -DPKGVERSION="(GCC) "  contain spaces
# that would word-split if we accumulated bare strings and re-expanded.
shell_quote() {
    printf "'%s'" "$(printf '%s' "$1" | sed "s/'/'\\\\''/g")"
}

# Re-parse to extract structured info (output, inputs, flags).
# Each category is a string of shell-quoted args, expanded via `eval`
# at the cpp / cc invocation. Storing bare $arg and re-expanding via
# unquoted "$CPP_FLAGS" word-splits on embedded spaces in -D values.
OUTPUT=""
INPUTS=""
CPP_FLAGS=""
CC_FLAGS=""
PREV=""
for arg in "$@"; do
    if [ "$PREV" = "-o" ]; then
        OUTPUT="$arg"
        PREV=""
        continue
    fi
    PREV=""
    qarg=$(shell_quote "$arg")
    case "$arg" in
        -c) MODE="compile" ;;
        -o) PREV="-o" ;;
        -I*|-D*|-U*)
            CPP_FLAGS="$CPP_FLAGS $qarg"
            ;;
        -include|-isystem|-iquote)
            CPP_FLAGS="$CPP_FLAGS $qarg"
            PREV="$arg"
            ;;
        -std=*)
            STD_FLAG="$arg"
            CPP_FLAGS="$CPP_FLAGS $qarg"
            ;;
        -W*|-f*|-g*|-O*|-m*|-pipe|-pthread)
            CC_FLAGS="$CC_FLAGS $qarg"
            ;;
        -l*|-L*)
            CC_FLAGS="$CC_FLAGS $qarg"
            ;;
        *.cpp|*.cc|*.cxx|*.C|*.c|*.ii|*.i)
            INPUTS="$INPUTS $qarg"
            ;;
        *.o|*.a|*.so)
            # Object/library files — pass through for linking
            CC_FLAGS="$CC_FLAGS $qarg"
            ;;
        *)
            # Unknown — pass to both
            CPP_FLAGS="$CPP_FLAGS $qarg"
            CC_FLAGS="$CC_FLAGS $qarg"
            ;;
    esac
    # Handle -include / -isystem with separate value arg
    case "$PREV" in
        -include|-isystem|-iquote)
            # Will be captured on next iteration as the value
            ;;
    esac
done

# If no C++ source files, this is a pure link or C compile — pass through
if [ -z "$INPUTS" ]; then
    log "No source files — passthrough to $SEA_CC"
    exec $SEA_CC "$@"
fi

if [ "$MODE" = "link" ]; then
    log "Link mode — passthrough to $SEA_CC"
    exec $SEA_CC "$@"
fi

# Unpack INPUTS (space-separated shell-quoted) into positional params
# so we can iterate without losing args that contain spaces.
eval "set -- $INPUTS"

# Default output: derive from input (foo.cpp → foo.o)
if [ -z "$OUTPUT" ] && [ "$MODE" = "compile" ]; then
    OUTPUT=$(echo "$1" | sed 's/\.[^.]*$/.o/')
fi

# Compile mode: preprocess → sea-front → cc -c
for src in "$@"; do
    log "Processing: $src"

    TMPDIR="${TMPDIR:-/tmp}"
    base=$(basename "$src" | sed 's/\.[^.]*$//')
    pp_file="$TMPDIR/sf_pp_${base}_$$.i"
    c_file="$TMPDIR/sf_out_${base}_$$.c"

    # Step 1: Preprocess
    #
    # Defines we inject to steer gcc / libc / libcpp away from
    # inline-asm and vectorized code paths that sea-front can't lower:
    #   -DGCC_VERSION=4004
    #       Disables libcpp's SSE2/SSE4 vectorized line scanner
    #       (gated on GCC_VERSION >= 4005) while keeping all other
    #       libcpp feature checks (2007, 3000) enabled. Forces the
    #       scalar search_line_acc_char fallback. sea-front discards
    #       inline asm bodies, so the vectorized fast-path would
    #       compile to an empty function and crash at runtime.
    SF_DEFINES="-DGCC_VERSION=4004"
    # Default to C++03 when no -std= flag is given. gcc 4.8 source is
    # C++03; without this, g++ 13 defaults to C++17 and libstdc++ 13
    # headers emit C++17 constructs (std::byte etc.) that sea-front
    # doesn't handle.
    if [ -z "$STD_FLAG" ]; then STD_FLAG="-std=c++03"; fi
    # When SEA_LIBSTDCXX_SRC is set, use -nostdinc++ and point at the
    # target's own libstdc++ headers instead of the host's. Required
    # for bootstrappable builds where the host libstdc++ is a different
    # era (e.g. host is C++17, target is C++03).
    STDCXX_FLAGS=""
    if [ -n "$SEA_LIBSTDCXX_SRC" ] && [ -n "$SEA_LIBSTDCXX_BUILD" ]; then
        STDCXX_FLAGS="-nostdinc++ -I${SEA_LIBSTDCXX_BUILD}/x86_64-unknown-linux-gnu -I${SEA_LIBSTDCXX_BUILD} -I${SEA_LIBSTDCXX_SRC} -I${SEA_LIBSTDCXX_SRC}/c_global"
    fi

    # Use eval so CPP_FLAGS / CC_FLAGS preserve args containing spaces
    # (e.g. -DPKGVERSION="(GCC) "). $src and $pp_file are quoted
    # explicitly inside the eval string.
    qsrc=$(shell_quote "$src")
    qpp=$(shell_quote "$pp_file")
    qcfile=$(shell_quote "$c_file")
    qout=$(shell_quote "$OUTPUT")

    log "  Preprocess: $SEA_CPP -E $SF_DEFINES $STD_FLAG $STDCXX_FLAGS $CPP_FLAGS $src"
    eval "$SEA_CPP -E $SF_DEFINES $STD_FLAG $STDCXX_FLAGS $CPP_FLAGS $qsrc -o $qpp" 2>/dev/null

    # Step 2: Transpile C++ → C
    log "  Transpile: $SEA_FRONT --emit-c $pp_file"
    eval "$SEA_FRONT --emit-c $qpp > $qcfile" 2>/dev/null

    # Step 3: Compile C → .o
    # Use -std=c99 for gcc 4.7 compatibility (for-init declarations)
    log "  Compile: $SEA_CC -std=c99 -c $CC_FLAGS -o $OUTPUT $c_file"
    eval "$SEA_CC -std=c99 -c $CC_FLAGS -o $qout $qcfile"

    # Cleanup
    rm -f "$pp_file" "$c_file"
done

log "Done"
